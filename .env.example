SLEPI_PUBLIC_DATA_BASE_URL=https://cdn.example.com/slepi

SLEPI_OBJECT_STORAGE_BUCKET=your-bucket-name
SLEPI_OBJECT_STORAGE_REGION=auto
SLEPI_OBJECT_STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
SLEPI_OBJECT_STORAGE_ACCESS_KEY_ID=your-access-key-id
SLEPI_OBJECT_STORAGE_SECRET_ACCESS_KEY=your-secret-access-key
SLEPI_OBJECT_STORAGE_SESSION_TOKEN=
SLEPI_OBJECT_STORAGE_KEY_PREFIX=slepi
SLEPI_OBJECT_STORAGE_CACHE_CONTROL=public, max-age=300
